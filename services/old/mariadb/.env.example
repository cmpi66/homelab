SERVICE_NAME=mariadb
COMPOSE_PROJECT_NAME=homelab-mariadb
CONTAINER_NAME=homelab-mariadb
MARIADB_IMAGE=mariadb:11.8
MARIADB_PORT=3306
SERVICE_DATA_SUBDIR=services/mariadb
MARIADB_DATA_DIR=/var/lib/mysql
MARIADB_INIT_DIR=/docker-entrypoint-initdb.d
MARIADB_DATABASE=appdb
MARIADB_USER=appuser
MARIADB_PASSWORD=replace-me
MARIADB_ROOT_PASSWORD=replace-me
