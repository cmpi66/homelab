# SSH / Docker host
HOMELAB_PROJECT=homelab
HOMELAB_CONTEXT=homelab
HOMELAB_REMOTE_USER=chris
HOMELAB_REMOTE_HOST=10.27.27.11
HOMELAB_REMOTE_PORT=22
